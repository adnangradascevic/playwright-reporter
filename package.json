{
  "name": "@sentinelqa/playwright-reporter",
  "version": "0.1.36",
  "private": false,
  "description": "Playwright reporter for CI debugging with optional Sentinel cloud dashboards",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adnangradascevic/playwright-reporter.git"
  },
  "homepage": "https://github.com/adnangradascevic/playwright-reporter#readme",
  "bugs": {
    "url": "https://github.com/adnangradascevic/playwright-reporter/issues"
  },
  "keywords": [
    "sentinelqa",
    "playwright",
    "ci",
    "debugging",
    "reporter"
  ],
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": "./dist/index.js",
    "./reporter": "./dist/reporter.js",
    "./fixtures": "./dist/fixtures.js"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "dependencies": {
    "@sentinelqa/uploader": "^0.1.24"
  },
  "devDependencies": {
    "@types/node": "^20.19.32",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "publish:dry": "npm run build && npm pack --dry-run"
  }
}
